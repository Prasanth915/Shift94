# ==============================================================================
# Shift94 — Environment Variables
# ==============================================================================
# Copy this file to .env in the backend directory and configure appropriately.
# NEVER commit the actual .env file to version control.

# Database
# Connects to your local PostgreSQL instance
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shift9?schema=public"

# JWT Configuration
# Secret key used to sign and verify session tokens (Min 32 characters)
JWT_SECRET="replace_with_a_secure_jwt_secret_at_least_32_characters"
JWT_EXPIRES_IN="7d"

# Encryption Configuration
# Hex key for encrypting OAuth tokens (Exactly 64 hex characters / 32 bytes)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# LinkedIn OAuth Credentials
LINKEDIN_CLIENT_ID="your_linkedin_client_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"
LINKEDIN_REDIRECT_URI="http://localhost:5173/oauth/callback"

# GitHub OAuth Credentials
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_REDIRECT_URI="http://localhost:5173/oauth/callback"

# File Upload Configuration
# Directory path on the local machine where project cover images are stored
UPLOAD_PATH="./uploads"

# Application URLs
APP_URL="http://localhost:5173"
API_URL="http://localhost:5000"
PORT=5000
NODE_ENV="development"
