datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// Enums
// ==========================================

enum Platform {
  LINKEDIN
  GITHUB
  INSTAGRAM
  PORTFOLIO
}

enum PublishStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  EXPIRED
}

// ==========================================
// Models
// ==========================================

model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  avatar    String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  // Relationships
  connectedAccounts ConnectedAccount[]
  projects          Project[]

  @@map("users")
}

model ConnectedAccount {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  platform     Platform
  accessToken  String           @db.Text
  refreshToken String?          @db.Text
  username     String?          @db.VarChar(255)
  profileUrl   String?          @db.VarChar(255)
  status       ConnectionStatus @default(CONNECTED)
  createdAt    DateTime         @default(now()) @db.Timestamp(6)

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Constraints and Indexes
  @@unique([userId, platform])
  @@index([userId])
  @@map("connected_accounts")
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @db.Uuid
  title       String        @db.VarChar(255)
  subtitle    String?       @db.VarChar(255)
  description String        @db.Text
  image       String?       @db.VarChar(255)
  githubUrl   String?       @db.VarChar(255)
  demoUrl     String?       @db.VarChar(255)
  techStack   String[]      @default([]) @db.VarChar(255)
  tags        String[]      @default([]) @db.VarChar(255)
  status      ProjectStatus @default(DRAFT)
  createdAt   DateTime      @default(now()) @db.Timestamp(6)
  updatedAt   DateTime      @updatedAt @db.Timestamp(6)

  // Relationships
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishLogs PublishLog[]

  // Indexes
  @@index([userId])
  @@map("projects")
}

model PublishLog {
  id          String        @id @default(uuid()) @db.Uuid
  projectId   String        @db.Uuid
  platform    Platform
  status      PublishStatus @default(PENDING)
  externalUrl String?       @db.VarChar(255)
  apiResponse Json?         @db.JsonB
  createdAt   DateTime      @default(now()) @db.Timestamp(6)

  // Relationships
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([projectId])
  @@index([createdAt(sort: Desc)])
  @@map("publish_logs")
}
